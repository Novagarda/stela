<footer class="site-footer">
  <div class="site-footer__band">
    <picture>
      <source
        media="(max-width: 767.98px)"
        srcset="{{ '/assets/images/footer-band-stela-mobile.svg' | url }}"
      />
      <img
        class="site-footer__band-image"
        src="{{ '/assets/images/footer-band-stela.svg' | url }}"
        alt="Stela"
        width="1400"
        height="84"
        loading="lazy"
        decoding="async"
      />
    </picture>
  </div>

  <div class="site-footer__inner">
    <div class="site-footer__col site-footer__col--logo">
      <a
        class="site-footer__logo"
        href="{{ site.footer.concello.url }}"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          class="site-footer__logo-image"
          src="{{ '/assets/images/logo-concello-santiago.svg' | url }}"
          alt="{{ site.footer.concello.name }}"
          width="79"
          height="104"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>

    <div class="site-footer__col site-footer__col--social">
      <nav class="site-footer__nav" aria-label="Redes sociais">
        <ul class="site-footer__list">
          {% for link in site.footer.social %}
            <li class="site-footer__list-item">
              <a
                class="site-footer__link"
                href="{{ link.href }}"
                target="_blank"
                rel="noopener noreferrer"
              >
                {{ link.label }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    </div>

    <div class="site-footer__col site-footer__col--legal">
      <nav class="site-footer__nav" aria-label="Información legal">
        <ul class="site-footer__list">
          {% for link in site.footer.legal %}
            <li class="site-footer__list-item">
              <a
                class="site-footer__link"
                href="{{ link.href | url }}"
                {% if link.target %}target="{{ link.target }}"{% endif %}
                {% if link.target == "_blank" %}rel="noopener noreferrer"{% endif %}
              >
                {{ link.label }}
              </a>
            </li>
          {% endfor %}
          <li class="site-footer__list-item">
            <span class="site-footer__text">{{ site.footer.copyright | replace("{{ year }}", year) }}</span>
          </li>
        </ul>
      </nav>
    </div>

    <div class="site-footer__col site-footer__col--contact">
      <address class="site-footer__contact">
        {% for line in site.footer.contact.address %}
          <span class="site-footer__contact-line">{{ line }}</span>
        {% endfor %}
        <a class="site-footer__link" href="mailto:{{ site.footer.contact.email }}">
          {{ site.footer.contact.email }}
        </a>
        <a class="site-footer__link" href="tel:{{ site.footer.contact.phone | replace(' ', '') }}">
          {{ site.footer.contact.phone }}
        </a>
      </address>
    </div>
  </div>
</footer>
