<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or site.description }}" />
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    <link rel="stylesheet" href="{{ '/assets/css/flickity.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}" />
  </head>
  <body>
    <header class="site-header">
      <a class="site-logo" href="{{ '/' | url }}">{{ site.title }}</a>
      <nav class="site-nav" aria-label="Seccións">
        {% for item in site.navigation %}
          <a href="{{ '/' | url }}#{{ item.id }}">{{ item.label }}</a>
        {% endfor %}
      </nav>
    </header>

    <main class="site-main">
      {{ content | safe }}
    </main>

    {% include "components/footer.njk" %}
  </body>
</html>
