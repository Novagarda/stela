<!DOCTYPE html>
<html lang="gl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or site.description }}" />
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    <link rel="icon" href="{{ '/assets/favicon.ico' | url }}" sizes="any" />
    <link rel="icon" href="{{ '/assets/favicon-32x32.png' | url }}" type="image/png" sizes="32x32" />
    <link rel="icon" href="{{ '/assets/favicon-16x16.png' | url }}" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="{{ '/assets/apple-touch-icon.png' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/flickity.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/plyr.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}" />
  </head>
  <body>
    {# <header class="site-header">
      <a class="site-logo" href="{{ '/' | url }}">{{ site.title }}</a>
      <nav class="site-nav" aria-label="Seccións">
        {% for item in site.navigation %}
          <a href="{{ '/' | url }}#{{ item.id }}">{{ item.label }}</a>
        {% endfor %}
      </nav>
    </header> #}

    <main class="site-main">
      {{ content | safe }}
    </main>

    {% include "components/footer.njk" %}
  </body>
</html>
