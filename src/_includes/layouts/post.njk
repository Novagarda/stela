---
layout: layouts/base.njk
---

<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    {% if date %}
      <time class="post-date" datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    {% endif %}
  </header>
  <div class="prose">
    {{ content | safe }}
  </div>
</article>
