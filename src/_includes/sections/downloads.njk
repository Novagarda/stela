<section class="section section--downloads"{% if section.data.id %} id="{{ section.data.id }}"{% endif %}>
  <div class="section__inner downloads">
    <ul class="downloads__list">
      {% for item in section.data.items %}
        <li class="downloads__item">
          {% if item.href %}
            <a
              class="downloads__link"
              href="{{ item.href | url }}"
              target="_blank"
              rel="noopener"
            >
              {{ item.label }}
            </a>
          {% else %}
            <span class="downloads__label">{{ item.label }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
