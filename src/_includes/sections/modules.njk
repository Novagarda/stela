<section class="section section--modules"{% if section.data.id %} id="{{ section.data.id }}"{% endif %}>
  <div class="section__inner modules">
    {% for item in section.data.items %}
      <figure class="modules__item">
        {% if item.src %}
          <img
            class="modules__image"
            src="{{ item.src | url }}"
            alt="{{ item.alt }}"
            {% if item.width %}width="{{ item.width }}"{% endif %}
            {% if item.height %}height="{{ item.height }}"{% endif %}
            loading="lazy"
            decoding="async"
          />
        {% else %}
          <div class="modules__placeholder" role="img" aria-label="{{ item.alt }}"></div>
        {% endif %}
      </figure>
    {% endfor %}
  </div>
</section>
