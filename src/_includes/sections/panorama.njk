{% set itemsToShow = section.data.itemsToShow or 3 %}
{% set ratio = section.data.ratio or "original" %}

<section class="section section--bus"{% if section.data.id %} id="{{ section.data.id }}"{% endif %}>
  <div class="section__header">
    {% if section.data.title %}<h2>{{ section.data.title }}</h2>{% endif %}
    {% if section.data.lead %}<p class="section__lead">{{ section.data.lead }}</p>{% endif %}
  </div>

  <div data-video-scrub>
    <div
      class="video-wrap video-wrap--scrub"
      data-video-scrub-viewport
      tabindex="0"
      aria-label="{{ section.data.ariaLabel or 'Recorre el autobús moviendo el ratón de izquierda a derecha' }}"
    >
      <video
        class="video video--source"
        src="{{ section.data.src | url }}"
        playsinline
        muted
        preload="auto"
      ></video>
      {% if section.data.poster %}
      <img
        class="video-scrub__poster"
        src="{{ section.data.poster | url }}"
        alt=""
        aria-hidden="true"
        data-video-scrub-poster
      >
      {% endif %}
      <canvas class="video video--canvas" data-video-scrub-canvas aria-hidden="true"></canvas>
      <button
        type="button"
        class="video-scrub__unlock"
        data-video-scrub-unlock
        aria-label="{{ section.data.unlockLabel or 'Desliza para explorar el autobús' }}"
      >
        <span class="video-scrub__hint-track" aria-hidden="true">
          <span class="video-scrub__hint-thumb"></span>
        </span>
        <span class="video-scrub__unlock-label">{{ section.data.unlockLabel or "Desliza para explorar" }}</span>
      </button>
    </div>
    <div class="video-scrub__controls" aria-hidden="true">
      <div class="video-scrub__progress">
        <div class="video-scrub__progress-fill" data-video-scrub-progress></div>
        <span class="video-scrub__progress-dot" data-video-scrub-progress-dot aria-hidden="true"></span>
      </div>
      <p class="video-scrub__time">
        <span data-video-scrub-current>0.0</span>
        <span class="video-scrub__time-sep">/</span>
        <span data-video-scrub-duration>0.0</span>
        <span class="video-scrub__time-unit">s</span>
      </p>
    </div>
  </div>

  {% if section.data.items %}
    <div class="block block-slider-3">
      <div
        data-items="{{ itemsToShow }}"
        class="inner slider slider-js{% if section.data.items | length <= 1 %} slider--single{% endif %} --ratio-{{ ratio }}"
        data-slider-no-arrows="true"
        data-slider-dots="true"
      >
        {% for item in section.data.items %}
          <div class="slide">
            <div class="item">
              {% if item.src %}
                {% include "components/slider-image.njk" %}
              {% else %}
                <div class="image image--placeholder" role="img" aria-label="{{ item.alt }}"></div>
              {% endif %}
              {% if section.data.showCaptions and (item.label or item.caption) %}
                <div class="item-caption item-caption--overlay">
                  {% if item.label %}<span class="item-caption__label">{{ item.label }}</span>{% endif %}
                  {% if item.caption %}<span class="item-caption__text">{{ item.caption }}</span>{% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
        <div class="slider-controls" data-slider-controls>
          <div class="slider-controls__dots" data-slider-controls-dots></div>
          <div class="slider-controls__arrows" data-slider-controls-arrows></div>
        </div>
      </div>
    </div>
  {% endif %}

  {% if section.templateContent %}
    <div class="prose">
      {{ section.templateContent | safe }}
    </div>
  {% endif %}
</section>
<script type="module" src="{{ '/assets/js/panorama.js' | url }}"></script>
{% if section.data.items %}
  <script type="module" src="{{ '/assets/js/slider.js' | url }}"></script>
{% endif %}
